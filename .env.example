# Supabase (auto-provided by Lovable Cloud — do NOT edit .env directly)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# Quero Armas — feature flag /cadastro refinado (Jeito 3, 5 etapas editoriais)
# true  → /cadastro abre QACadastroRefinadoPage (nova UI)
# false/ausente → /cadastro abre QACadastroPublicoPage (fluxo legado intacto)
# Override em runtime via querystring: /cadastro?cadastro_v2=1 ou ?cadastro_v2=0
VITE_QA_CADASTRO_V2_ENABLED=true